# ─────────────────────────────────────────────
# ExpiryTracker — environment variable reference
# ─────────────────────────────────────────────
# Copy this file to .env (never commit .env).
# All variables are optional unless marked REQUIRED.

# ── Database ──────────────────────────────────
# REQUIRED. PostgreSQL connection string.
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/expirytracker

# ── API Server ────────────────────────────────
# REQUIRED. Port the Express API server listens on.
PORT=3001

# Node environment. Use "production" in deployed environments.
# Affects log formatting (pretty-print vs. JSON) and certain security defaults.
NODE_ENV=development

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Business Logic ────────────────────────────
# Days within which an item is classified as "expiring soon".
# Default: 30
EXPIRING_SOON_DAYS=30

# Days within which an item counts toward the "expiring this week" dashboard bucket.
# Default: 7
EXPIRING_THIS_WEEK_DAYS=7

# Human-readable application name used in logs.
# Default: ExpiryTracker
APP_NAME=ExpiryTracker

# ── Frontend (Vite) ───────────────────────────
# These are injected by the Replit/Vite build system and do not need
# to be set manually in most development environments.
# VITE_API_BASE_URL=http://localhost:3001
